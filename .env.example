# Supabase Configuration
SUPABASE_URL=https://dgrtziddrgpqenppehae.supabase.co
SUPABASE_SERVICE_KEY=TBD-Obtener-del-dashboard-Supabase

# API Security
HERMES_API_KEY=hermes-secret-key-change-me-in-production

# Redis (usar default si se usa docker-compose)
REDIS_URL=redis://redis:6379/0

# Worker Configuration
WORKER_TIMEOUT=3600
WORKER_CONCURRENCY=4

# Logging
LOG_LEVEL=INFO
LOG_DIR=/app/logs

# Data
DATA_DIR=/app/data

# LanceDB memory (mandatory lookup before inference response)
LANCEDB_INSTANCE_NAME=hermes-inference-memory-v1
LANCEDB_ROOT_PATH=/app/data/lancedb
LANCEDB_TABLE=inference_memory
LANCEDB_EMBEDDING_DIM=384
